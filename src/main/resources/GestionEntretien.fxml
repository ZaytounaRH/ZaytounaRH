<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Pos?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ListView?>

<FlowPane fx:id="entretienCards" hgap="20" vgap="20" alignment="CENTER" prefWidth="1000" prefHeight="800" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17" fx:controller="tn.esprit.controllers.GestionEntretien">
    <children>
        <!-- Title -->
        <Label layoutX="400.0" layoutY="20.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Gestion des Entretiens" />

        <!-- Section for Adding/Updating an Entretien -->
        <VBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 10px;">
            <Label text="Nom de l'Entretien" />
            <TextField fx:id="tfNomEntretien" promptText="Nom de l'Entretien" />

            <Label text="Date de l'Entretien" />
            <DatePicker fx:id="dateEntretienPicker" />

            <Label text="Type d'Entretien" />
            <ComboBox fx:id="typeEntretienComboBox" promptText="Choisir le type d'entretien">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String>PRESENTIEL</String>
                        <String>DISTANCIEL</String>
                        <String>TELEPHONIQUE</String>
                    </FXCollections>
                </items>
            </ComboBox>

            <Label text="Statut de l'Entretien" />
            <ComboBox fx:id="statutEntretienComboBox" promptText="Choisir le statut de l'entretien">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String>PLANIFIE</String>
                        <String>EN_COURS</String>
                        <String>TERMINE</String>
                        <String>ANNULE</String>
                    </FXCollections>
                </items>
            </ComboBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Ajouter Entretien" onAction="#ajouterEntretien" />
            </HBox>

            <!-- Sélectionner les Candidats -->
            <Label text="Sélectionnez un Candidat:"/>
            <ComboBox fx:id="candidatsComboBox" promptText="Choisir un Candidat"/>

            <!-- Bouton d'affectation -->
            <Button fx:id="affecterEntretienButton" text="Affecter Entretien au Candidat" onAction="#affecterEntretien"/>

            <VBox fx:id="cardsContainer" spacing="10" alignment="TOP_CENTER">
                <!-- Les cartes des entretiens seront ajoutées ici dynamiquement -->
            </VBox>

            <Button text="Afficher Candidats" onAction="#afficherCandidatsParEntretien" />
            <Button text="Modifier Candidats" onAction="#modifierCandidatsEntretien" />
            <Button text="Supprimer Candidat de l'entretien" onAction="#supprimerCandidatEntretien" />

        </VBox>

        <!-- Section for Displaying Entretien Details -->
        <Label layoutX="-50.0" layoutY="950.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Liste des Entretiens" />

        <!-- FlowPane for dynamically added Entretien Cards -->
        <FlowPane fx:id="entretienFlowPane" hgap="10" vgap="10" alignment="CENTER" prefWidth="900" prefHeight="600">
            <!-- Dynamically added Entretien Cards will appear here -->
        </FlowPane>

        <!-- Label for displaying messages -->
        <Label fx:id="lbEntretiens" layoutX="50.0" layoutY="640.0" prefWidth="980.0" style="-fx-text-fill: red;" />
    </children>
</FlowPane>
