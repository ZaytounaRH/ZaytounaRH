<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="tn.esprit.controllers.GestionEntretien" stylesheets="@css/styles.css">
    <center>
        <VBox spacing="10" alignment="CENTER" styleClass="form-container">
            <Label text="Ajout d'un Entretien" styleClass="form-title" />

            <HBox spacing="10">
                <Label text="Date de l'entretien :" />
                <DatePicker fx:id="dateEntretienPicker" />
            </HBox>

            <HBox spacing="10">
                <Label text="Heure de l'entretien :" />
                <Spinner fx:id="heureEntretienSpinner" />
            </HBox>

            <HBox spacing="10">
                <Label text="Type d'entretien :" />
                <ComboBox fx:id="typeEntretienComboBox" promptText="Sélectionnez le type" />
            </HBox>

            <HBox spacing="10">
                <Label text="Statut de l'entretien :" />
                <ComboBox fx:id="statutEntretienComboBox" promptText="Sélectionnez le statut" />
            </HBox>

            <HBox spacing="10">
                <Label text="Commentaire :" />
                <TextArea fx:id="commentaireTextArea" prefRowCount="3" prefColumnCount="20" />
            </HBox>

            <Button fx:id="ajouterButton" text="Ajouter" onAction="#ajouterEntretien" styleClass="add-button" />
        </VBox>
    </center>
</BorderPane>
