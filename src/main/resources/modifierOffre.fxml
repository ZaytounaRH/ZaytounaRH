<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="tn.esprit.controllers.ModifierOffreController">
    <VBox alignment="CENTER" prefHeight="500.0" prefWidth="282.0" spacing="10">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Label text="Titre de l'offre" />
        <TextField fx:id="tfTitre" promptText="Saisir le titre" />

        <Label text="Description" />
        <TextField fx:id="tfDescription" promptText="Saisir la description" />

        <Label text="Salaire proposé" />
        <TextField fx:id="tfSalaire" promptText="Saisir le salaire" />

        <Label text="Date de publication" />
        <DatePicker fx:id="dpDatePublication" />

        <Label text="Statut de l'offre" />
        <ComboBox fx:id="cbStatut" promptText="Choisir le statut" />

        <Label text="Responsable RH" />
        <ComboBox fx:id="cbResponsableRH" promptText="Sélectionner un responsable" />

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="btnEnregistrer" text="Enregistrer" onAction="#enregistrerOffre" />
            <Button onAction="#annulerModification" text="Annuler" />
        </HBox>
    </VBox>
</AnchorPane>
