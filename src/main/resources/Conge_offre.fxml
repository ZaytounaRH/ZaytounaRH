<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="542.0" prefWidth="1005.0" xmlns="http://javafx.com/javafx/23.0.1"
            stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.GestionGlobal">

    <children>

        <!-- Titre de l'application -->
        <Label text="Gestion RH" layoutX="380.0" layoutY="16.0" styleClass="title-label"/>

        <!-- TabPane pour gérer les différentes sections -->
        <TabPane layoutX="16.0" layoutY="60.0" prefWidth="973.0" prefHeight="430.0">

            <!-- Onglet pour la gestion des congés -->
            <Tab text="Gestion des Congés">
                <AnchorPane>
                    <Label text="Gestion des Congés" layoutX="120.0" layoutY="20.0" styleClass="text-title"/>

                    <Label text="Date Début:" layoutX="50.0" layoutY="75.0" styleClass="text"/>
                    <DatePicker fx:id="dpDateDebut" layoutX="150.0" layoutY="70.0" styleClass="text-field"/>

                    <Label text="Date Fin:" layoutX="50.0" layoutY="125.0" styleClass="text"/>
                    <DatePicker fx:id="dpDateFin" layoutX="150.0" layoutY="120.0" styleClass="text-field"/>

                    <Label text="Motif:" layoutX="50.0" layoutY="175.0" styleClass="text"/>
                    <TextField fx:id="tfMotif" layoutX="150.0" layoutY="170.0" promptText="Motif" styleClass="text-field"/>

                    <!-- Ajouter le bouton de connexion -->
                    <Label text="Se connecter en tant qu'employé" layoutX="50.0" layoutY="220.0" styleClass="text"/>
                    <Button text="Se connecter" layoutX="150.0" layoutY="250.0" onAction="#handleLoginButton" styleClass="button"/>

                    <Button text="Ajouter" layoutX="150.0" layoutY="300.0" onAction="#ajouterConge" styleClass="button"/>

                    <!-- Label pour afficher les messages d'erreur ou de succès -->
                    <Label fx:id="lbConges" layoutX="50.0" layoutY="340.0" text="" styleClass="label"/>

                    <!-- Tableview -->
                    <TableView fx:id="tvConges" layoutX="50.0" layoutY="380.0" prefWidth="300.0" prefHeight="120.0" styleClass="list-view">
                        <columns>
                            <TableColumn text="Date Début" fx:id="colDateDebut" prefWidth="100.0"/>
                            <TableColumn text="Date Fin" fx:id="colDateFin" prefWidth="100.0"/>
                            <TableColumn text="Motif" fx:id="colMotif" prefWidth="100.0"/>
                        </columns>
                    </TableView>
                </AnchorPane>
            </Tab>

            <!-- Onglet pour la gestion des offres d'emploi -->
            <Tab text="Gestion des Offres d'Emploi">
                <AnchorPane>
                    <!-- Section d'ajout d'offre -->
                    <VBox layoutX="16.0" layoutY="60.0" spacing="20" alignment="CENTER">
                        <TextField fx:id="tfTitre" promptText="Titre de l'offre" />
                        <TextField fx:id="tfDescription" promptText="Description" />
                        <TextField fx:id="tfSalaire" promptText="Salaire" />
                        <DatePicker fx:id="dpDatePublication" promptText="Date de publication" />
                        <ComboBox fx:id="cbStatut" promptText="Statut de l'offre" />

                        <!-- Bouton pour ajouter une offre -->
                        <Button layoutX="48.0" onAction="#ajouterOffre" text="Ajouter Offre" />
                    </VBox>

                    <!-- Section d'affichage des offres -->
                    <VBox layoutX="676.0" layoutY="60.0" spacing="20" alignment="CENTER">
                        <ListView fx:id="listViewOffres" prefHeight="250.0" prefWidth="300.0"/>
                        <Button layoutX="763.0" layoutY="437.0" onAction="#afficherOffres" text="Afficher Offres" />
                        <Button text="Supprimer" onAction="#supprimerOffre" />
                        <Button text="Modifier" onAction="#modifierOffre" />

                        <!-- Nouveau bouton pour générer le PDF -->
                        <Button text="Générer PDF" onAction="#genererPDF" />
                    </VBox>
                </AnchorPane>
            </Tab>

        </TabPane>
    </children>
</AnchorPane>
